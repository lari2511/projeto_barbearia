{
  "name": "nome-do-app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "cap:sync": "npm run build && npx cap sync",
    "cap:open:android": "npx cap open android",
    "cap:open:ios": "npx cap open ios",
    "cap:run:android": "npm run cap:sync && npx cap run android",
    "cap:run:ios": "npm run cap:sync && npx cap run ios",
    "android:build": "npm run build && npx cap sync android && cd android && .\\gradlew assembleRelease",
    "android:build:debug": "npm run build && npx cap sync android && cd android && .\\gradlew assembleDebug",
    "android:bundle:release": "npm run build && npx cap sync android && cd android && .\\gradlew bundleRelease"
  },
  "dependencies": {
    "@capacitor/android": "^8.0.0",
    "@capacitor/cli": "^7.4.4",
    "@capacitor/core": "^8.0.0",
    "@capacitor/geolocation": "^8.2.0",
    "@capacitor/ios": "^8.0.0",
    "@capacitor/local-notifications": "^8.2.0",
    "@capacitor/push-notifications": "^8.0.3",
    "@expo/vector-icons": "^14.0.0",
    "@react-native-firebase/messaging": "^17.0.0",
    "expo": "^50.0.0",
    "expo-location": "^16.0.0",
    "expo-task-manager": "^10.0.0",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.556.0",
    "qrcode": "^1.5.4",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-native": "^0.72.0",
    "vite-plugin-pwa": "^1.2.0",
    "workbox-window": "^7.4.0"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@eslint/js": "^9.39.1",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "autoprefixer": "^10.5.0",
    "eslint": "^9.39.1",
    "eslint-formatter-unix": "^9.0.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "postcss": "^8.5.15",
    "tailwindcss": "^4.3.0",
    "vite": "^7.2.4"
  }
}
