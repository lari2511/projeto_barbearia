# --- API BACKEND ---
# Desenvolvimento: http://localhost:8000
# Produção: https://api.barbermove.com.br
VITE_API_URL=http://localhost:8000

# --- WEBSOCKET ---
# Desenvolvimento: ws://localhost:8000/ws/notificacoes
# Produção: wss://api.barbermove.com.br/ws/notificacoes
VITE_WS_URL=ws://localhost:8000/ws/notificacoes

# --- MODO ---
VITE_DEV_MODE=false
