/* BACKUP of painel.css - created before clearing by assistant */

/* Original content preserved for rollback. */

/* --- Original file below --- */
/* Estilos mínimos para evitar erro de import no Vite.
	 Arquivo intencionalmente simples — ajuste visual conforme necessário. */
:root{
	--bm-bg: #050406;
	--bm-surface: #0a0710;
	--bm-card: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(8,4,18,0.6));
	--bm-accent: linear-gradient(90deg,#7c3aed,#ff6b35);
	--bm-accent-plain: #ff6b35;
	--bm-purple-500: #2f0a3f;
	--bm-purple-600: #3a0f52;
	--bm-green: #10b981;
	--bm-border: rgba(255,255,255,0.04);
	--bm-muted: #9ca3af;
}
body{background:var(--bm-bg);color:#fff;font-family:Inter,ui-sans-serif,system-ui,-apple-system,"Segoe UI",Roboto,"Helvetica Neue",Arial}
.bm-toast{position:fixed}

/* Layout helpers used across the app */
.bm-app-frame{
	min-height:100vh;
	background: radial-gradient(1000px 500px at 8% 12%, rgba(120,24,120,0.18), transparent 8%), radial-gradient(900px 420px at 92% 88%, rgba(255,102,40,0.08), transparent 12%), var(--bm-bg);
}
.bm-shell-content{
	max-width:430px;
	margin:0 auto;
	padding:18px;
}

/* Cards and panels */
.bm-card{
	background: var(--bm-card);
	border: 1px solid var(--bm-border);
	border-radius: 18px;
	box-shadow: 0 24px 64px rgba(0,0,0,0.75), inset 0 1px 0 rgba(255,255,255,0.02);
	padding:18px;
}
.bm-panel{
	background: linear-gradient(180deg, rgba(255,255,255,0.015), rgba(255,255,255,0.01));
	border-radius: 12px;
	border: 1px solid rgba(255,255,255,0.025);
	padding:14px;
}

/* Accent elements */
.bm-accent-btn{
	background: var(--bm-accent);
	color: #fff;
	border-radius: 10px;
	padding:10px 14px;
	box-shadow: 0 10px 36px rgba(255,107,53,0.14);
	font-weight:800;
}

.bm-title{font-weight:900;font-size:34px;color:#fff;display:flex;align-items:center;gap:10px;text-shadow:0 3px 0 rgba(0,0,0,0.6)}

.bm-subtitle{color:var(--bm-muted);font-size:13px}

.bm-notif-btn{background:rgba(255,255,255,0.02);border:1px solid rgba(255,255,255,0.03);padding:8px;border-radius:12px;width:44px;height:44px}
.bm-notif-btn:hover{box-shadow:0 8px 20px rgba(0,0,0,0.6);transform:translateY(-1px)}

/* Bottom navigation */
.bm-bottom-nav{
	position:fixed;left:0;right:0;bottom:0;background:linear-gradient(180deg, rgba(0,0,0,0.4), rgba(0,0,0,0.6));backdrop-filter:blur(6px);border-top:1px solid rgba(255,255,255,0.03);padding:8px 12px;display:flex;justify-content:space-around;align-items:center;z-index:40;
}

.bm-muted{color:var(--bm-muted)}

/* Banners and pills */
.bm-banner{background:linear-gradient(180deg, rgba(255,255,255,0.01), rgba(0,0,0,0.28));padding:12px;border-radius:14px;border:1px solid rgba(255,255,255,0.03);display:flex;align-items:center;gap:12px}
.bm-warning{background:linear-gradient(90deg, rgba(255,138,61,0.06), rgba(0,0,0,0.0));border-left:4px solid rgba(255,138,61,0.95);padding:14px;border-radius:12px}
.bm-ghost-card{background:rgba(255,255,255,0.01);border:1px solid rgba(255,255,255,0.02);padding:14px;border-radius:12px}
.bm-pill{display:inline-block;padding:8px 12px;border-radius:999px;font-weight:800;font-size:13px;letter-spacing:0.2px}
.bm-pill.green{background:linear-gradient(90deg,#0ea5a3,#10b981);color:#042014}
.bm-pill.purple{background:linear-gradient(90deg,#6d28d9,#4c1d95);color:#fff}
.bm-pill.orange{background:linear-gradient(90deg,#ff6b35,#ff8a3d);color:#fff}
.bm-pill.small{padding:4px 8px;font-size:12px}
.bm-status{display:inline-flex;align-items:center;gap:8px}
.bm-status .dot{width:10px;height:10px;border-radius:999px}
.bm-status .dot.green{background:var(--bm-green)}

.bm-cta-orange{background:var(--bm-accent);color:#fff;padding:14px 18px;border-radius:14px;font-weight:900;display:inline-flex;align-items:center;gap:12px;box-shadow:0 20px 60px rgba(124,58,237,0.12), 0 18px 48px rgba(255,107,53,0.18);font-size:14px}

/* large card used on main screens */
.bm-card-large{padding:22px;border-radius:20px}
.bm-cta-green{background:linear-gradient(90deg,#10b981,#06d6a0);color:#042014;padding:12px 16px;border-radius:14px;font-weight:900;box-shadow:0 12px 36px rgba(16,185,129,0.14);display:inline-flex;align-items:center;gap:12px;font-size:14px}

/* Additional CTA variants */
.bm-cta-red{background:linear-gradient(90deg,#ff5252,#ff3333);color:#fff;padding:12px 14px;border-radius:12px;font-weight:800;box-shadow:0 10px 30px rgba(255,60,60,0.12)}
.bm-cta-blue{background:linear-gradient(90deg,#4299e1,#2b6cb0);color:#fff;padding:12px 14px;border-radius:12px;font-weight:800;box-shadow:0 10px 30px rgba(66,153,225,0.12)}
.bm-ghost-btn{background:transparent;border:1px solid rgba(255,255,255,0.06);padding:10px 12px;border-radius:12px;color:rgba(255,255,255,0.9)}

/* Card progress bar */
.bm-progress{height:6px;border-radius:6px}

/* Bottom nav refinement */
.bm-bottom-nav{max-width:430px;margin:0 auto;left:0;right:0;bottom:12px;padding:10px 14px;}
.bm-bottom-nav .nav-item{flex:1;text-align:center;color:rgba(255,255,255,0.7);display:flex;flex-direction:column;align-items:center;gap:4px}
.bm-bottom-nav .nav-item.active{color:var(--bm-accent-plain);}
.bm-bottom-nav .nav-item .bubble{width:44px;height:44px;border-radius:12px;display:flex;align-items:center;justify-content:center;background:transparent}
.bm-bottom-nav .nav-item.active .bubble{background:linear-gradient(90deg,#7c3aed,#ff6b35);box-shadow:0 18px 48px rgba(124,58,237,0.22), 0 12px 30px rgba(255,107,53,0.12)}

/* utility to create a softer card border similar to mobile refs */
.bm-card-soft{border:1px solid rgba(255,255,255,0.05);padding:16px;border-radius:16px;background:linear-gradient(180deg, rgba(255,255,255,0.01), rgba(0,0,0,0.48));box-shadow:0 12px 36px rgba(0,0,0,0.6)}

/* Accent and success card styles used on dashboard */
.bm-card-accent{background:linear-gradient(180deg, rgba(124,58,237,0.06), rgba(255,107,53,0.04));border:1px solid rgba(124,58,237,0.08);padding:14px;border-radius:16px}
.bm-card-success{background:linear-gradient(180deg, rgba(16,185,129,0.06), rgba(4,120,87,0.02));border:1px solid rgba(16,185,129,0.06);padding:14px;border-radius:16px}

