# ========================================
# CONFIGURAÇÕES DE PRODUÇÃO - BarberMove
# ========================================
# COPIE este arquivo para .env e preencha com seus valores reais

# --- SEGURANÇA ---
SECRET_KEY=GERE_UMA_CHAVE_FORTE_AQUI_MINIMO_32_CARACTERES
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_DAYS=7

# --- CORS (URLs permitidas para acessar a API) ---
# IMPORTANTE: Em produção, NUNCA use allow_origins=["*"]
# 
# Desenvolvimento (múltiplos origins, sem espaços):
# ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,http://127.0.0.1:5173
#
# Produção (seus domínios reais):
# ALLOWED_ORIGINS=https://seu-front.com,https://www.seu-front.com,https://app.seu-front.com
#
# Staging:
# ALLOWED_ORIGINS=https://staging.seu-front.com,https://staging-api.seu-front.com
ALLOWED_ORIGINS=https://seu-front.com,https://www.seu-front.com

# --- DATABASE ---
# Desenvolvimento: sqlite:///./barbearia.db
# Produção: postgresql://user:password@host:5432/database
DATABASE_URL=postgresql://usuario:senha@host:5432/database

# --- EMAIL (SMTP) ---
# Para recuperação de senha e verificação
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seuemail@gmail.com
SMTP_PASSWORD=sua_senha_de_app
SMTP_FROM=noreply@seu-dominio.com

# --- VERIFICAÇÃO DE EMAIL ---
# 0 = não obrigatório, 1 = obrigatório
REQUIRE_EMAIL_VERIFIED=1
VERIFICATION_LINK_BASE=https://sua-api.up.railway.app/api/v1/email/verificar?token=

# --- FRONTEND ---
# URL onde o frontend está hospedado
FRONTEND_URL=https://seu-front.com

# --- API ---
# URL onde a API está hospedada
API_URL=https://sua-api.up.railway.app

# --- DISTRIBUICAO APK ---
# Pasta usada pela API para servir arquivos .apk
# Exemplo: APK_PRONTO (raiz do projeto)
APK_DOWNLOAD_DIR=APK_PRONTO

# --- NGROK (apenas desenvolvimento) ---
# NGROK_URL=https://seu-subdominio.ngrok-free.app

# ========================================
# GUIA DE SEGURANÇA PARA PRODUÇÃO
# ========================================
# 1. NUNCA comita o arquivo .env no git (adicione em .gitignore)
# 2. SECRET_KEY: Use `python -c "import secrets; print(secrets.token_urlsafe(32))"`
# 3. ALLOWED_ORIGINS: Apenas seus domínios reais (sem wildcards)
# 4. DATABASE_URL: Use PostgreSQL em produção, não SQLite
# 5. SMTP: Configure com credenciais seguras
# 6. REQUIRE_EMAIL_VERIFIED: Mude para 1 em produção
# 7. Variáveis de ambiente: Use plataforma de hosting (Vercel, Railway, Heroku, etc)

